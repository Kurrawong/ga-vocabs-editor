skos:ConceptScheme prez:label "Concept Scheme"@en;
    prez:description "A set of concepts, optionally including statements about semantic relationships between those concepts"@en.
skos:definition prez:label "definition"@en;
    prez:description "A statement or formal explanation of the meaning of a concept"@en.
skos:prefLabel prez:label "preferred label"@en;
    prez:description "The preferred lexical label for a resource, in a given language"@en.
dcterms:created prez:label "Date Created"@en;
    prez:description "Date of creation of the resource."@en.
dcterms:creator prez:label "Creator"@en;
    prez:description "An entity responsible for making the resource."@en.
<https://linked.data.gov.au/org/ga> prez:label "Geoscience Australia";
    prez:description "Australia's pre-eminent public sector geoscience organisation. We are the nation's trusted advisor on the geology and geography of Australia. We apply science and technology to describe and understand the Earth for the benefit of Australia.".
dcterms:modified prez:label "Date Modified"@en;
    prez:description "Date on which the resource was changed."@en.
dcterms:publisher prez:label "Publisher"@en;
    prez:description "An entity responsible for making the resource available."@en.
rdfs:seeAlso prez:label "see also";
    prez:description "Further information about the subject resource.".
<https://pid.geoscience.gov.au/dataset/ga/147628> prez:label "Associated Resource Type";
    prez:description "The Geoscience Australia catalogue uses a profile of certain controlled vocabularies (codelists) from the ISO19115-1 metadata standard. A profile includes extra terms that are used by Geoscience Australia that do not appear in the original standard.".
owl:versionInfo prez:label "versionInfo";
    prez:description "The annotation property that provides version information for an ontology or another OWL construct.".
skos:historyNote prez:label "history note"@en;
    prez:description "A note about the past state/use/meaning of a concept"@en.
dcat:contactPoint prez:label "contact point"@en;
    prez:description "Relevant contact information for the catalogued resource. Use of vCard is recommended."@en.
prez:link prez:label "link".
prez:members prez:label "members".
<urn:catalog:default> prez:identifier "catalogue:default".
_:n3-30 prez:currentProfile prez:DefaultSchemeProfile.
skos:hasTopConcept prez:label "has top concept"@en;
    prez:description "Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies"@en.
